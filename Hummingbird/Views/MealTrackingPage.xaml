<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Hummingbird.Views.MealTrackingPage"
             Title="Comidas">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <Label Text="📊 Seguimiento de Comidas" FontSize="24" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" Padding="0,8,0,0"/>

            <!-- Period Picker -->
            <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="12">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="📅 Período:" FontSize="14" VerticalOptions="Center"/>
                    <Picker ItemsSource="{Binding Periods}"
                            SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                            HorizontalOptions="FillAndExpand"/>
                </HorizontalStackLayout>
            </Border>

            <Label Text="{Binding PeriodSummary}" FontSize="13" TextColor="{StaticResource Gray500}"/>

            <!-- Week Navigation -->
            <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="8">
                <Grid ColumnDefinitions="44,*,44">
                    <Button Grid.Column="0" Text="◀" Command="{Binding PreviousWeekCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                            FontSize="18" WidthRequest="44" HeightRequest="40" Padding="0"/>
                    <Label Grid.Column="1" Text="{Binding WeekLabel}" FontSize="14" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                    <Button Grid.Column="2" Text="▶" Command="{Binding NextWeekCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                            FontSize="18" WidthRequest="44" HeightRequest="40" Padding="0"/>
                </Grid>
            </Border>

            <!-- Meal Cards -->
            <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding MealCards}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Padding="16">
                            <VerticalStackLayout Spacing="12">

                                <!-- Header: emoji + name + expand button -->
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                        <Label Text="{Binding MealEmoji}" FontSize="20"/>
                                        <Label Text="{Binding MealName}" FontSize="18" FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Button Grid.Column="2" Text="{Binding ExpandIcon}"
                                            Command="{Binding ToggleExpandCommand}"
                                            BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                            FontSize="14" WidthRequest="40" HeightRequest="36" Padding="0"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                                <!-- Summary: Pre → Post -->
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                        <Label Text="Pre" FontSize="13" TextColor="{StaticResource Gray500}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PreAverage, StringFormat='{0:F0}'}"
                                               FontSize="28" FontAttributes="Bold"
                                               TextColor="{Binding PreColor}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PreCount, StringFormat='{0} lecturas'}"
                                               FontSize="11" TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center"
                                                         HorizontalOptions="Center" Spacing="2">
                                        <Label Text="→" FontSize="20" TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding DeltaText}" FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray500}" HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                        <Label Text="Post" FontSize="13" TextColor="{StaticResource Gray500}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PostAverage, StringFormat='{0:F0}'}"
                                               FontSize="28" FontAttributes="Bold"
                                               TextColor="{Binding PostColor}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PostCount, StringFormat='{0} lecturas'}"
                                               FontSize="11" TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Expandable Detail -->
                                <VerticalStackLayout Spacing="4" IsVisible="{Binding IsExpanded}">
                                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" Margin="0,4"/>

                                    <Grid ColumnDefinitions="55,*,20,*,50" IsVisible="{Binding HasData}">
                                        <Label Text="Día" FontSize="11" TextColor="{StaticResource Gray400}"/>
                                        <Label Grid.Column="1" Text="Pre" FontSize="11"
                                               TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="3" Text="Post" FontSize="11"
                                               TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                                        <Label Grid.Column="4" Text="Δ" FontSize="11"
                                               TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                                    </Grid>

                                    <VerticalStackLayout Spacing="2" BindableLayout.ItemsSource="{Binding Days}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="55,*,20,*,50" Padding="0,3">
                                                    <Label Text="{Binding DayLabel}" FontSize="12"
                                                           VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="1" Text="{Binding PreGlucose}"
                                                           FontSize="15" FontAttributes="Bold"
                                                           TextColor="{Binding PreColor}"
                                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="2" Text="→" FontSize="12"
                                                           TextColor="{StaticResource Gray400}"
                                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="3" Text="{Binding PostGlucose}"
                                                           FontSize="15" FontAttributes="Bold"
                                                           TextColor="{Binding PostColor}"
                                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                                    <Label Grid.Column="4" Text="{Binding DeltaText}"
                                                           FontSize="12" TextColor="{StaticResource Gray500}"
                                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label Text="Sin datos esta semana" FontSize="13"
                                           TextColor="{StaticResource Gray400}" IsVisible="{Binding NoData}"
                                           HorizontalTextAlignment="Center" Padding="0,8"/>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

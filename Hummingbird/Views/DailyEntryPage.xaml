<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Hummingbird.Views.DailyEntryPage"
             Title="Registro">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <Label Text="💉 Nuevo Registro" FontSize="24" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" Padding="0,8,0,0"/>

            <!-- Date, Time & Type -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="📅 Fecha" FontSize="13" TextColor="{StaticResource Gray500}"/>
                            <DatePicker Date="{Binding SelectedDate}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="🕐 Hora" FontSize="13" TextColor="{StaticResource Gray500}"/>
                            <TimePicker Time="{Binding SelectedTime}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="📌 Tipo de medición" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Picker Title="Seleccionar tipo"
                                ItemsSource="{Binding MeasurementTypesList}"
                                SelectedItem="{Binding SelectedMeasurementType, Mode=TwoWay}"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Measurements -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📊 Glicemia (mg/dL)" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Entry Keyboard="Numeric" Text="{Binding GlucoseText}" Placeholder="Ej: 120"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowCarbohydrates}">
                        <Label Text="🍞 Carbohidratos (g)" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Entry Keyboard="Numeric" Text="{Binding CarbohydratesText}" Placeholder="Ej: 45"/>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding ShowExtras}">
                        <Border StrokeShape="RoundRectangle 20" StrokeThickness="1"
                                IsVisible="{Binding ShowActivityChip}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                BackgroundColor="Transparent" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleActivityCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="🏃" FontSize="14"/>
                                <Label Text="Actividad" FontSize="12"
                                       TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                        <Border StrokeShape="RoundRectangle 20" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                BackgroundColor="Transparent" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleNotesCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="📝" FontSize="14"/>
                                <Label Text="Notas" FontSize="12"
                                       TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowActivityInput}">
                        <Label Text="🏃 Actividad" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Entry Text="{Binding Activity}" Placeholder="Ej: Caminata 30 min"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowNotesInput}">
                        <Label Text="📝 Observaciones" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Editor Text="{Binding Notes}" Placeholder="Notas adicionales..." HeightRequest="80"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Insulin Calculator -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Tertiary}}"
                    Padding="16" IsVisible="{Binding ShowInsulinCalculator}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🧮 Calculadora de Insulina" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"/>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#0D948833, Dark=#FFFFFF33}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Bolo de corrección" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                        <Label Grid.Column="1" Text="{Binding CorrectionDoseText, StringFormat='{0} u'}" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding ShowCarbohydrates}">
                        <Label Text="Bolo por comida" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                        <Label Grid.Column="1" Text="{Binding CarbDoseText, StringFormat='{0} u'}" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#0D948833, Dark=#FFFFFF33}"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Dosis sugerida" FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                        <Label Grid.Column="1" Text="{Binding SuggestedDose, StringFormat='{0} u'}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"/>
                    </Grid>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowSafeDose}">
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#0D948833, Dark=#FFFFFF33}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="🛡️ Dosis segura" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                                <Label Text="{Binding NightTargetText}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding SafeDoseText, StringFormat='{0} u'}"
                                   FontSize="20" FontAttributes="Bold" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"/>
                        </Grid>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Estado" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                        <HorizontalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="{Binding GlucoseStatus}" FontSize="14" FontAttributes="Bold"
                                   TextColor="{Binding GlucoseStatusColor}"/>
                            <Label Text="{Binding DifferenceText}" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="4" Margin="0,8,0,0">
                        <Label Text="💉 Insulina aplicada (unidades)" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"/>
                        <Entry Keyboard="Numeric" Text="{Binding AppliedInsulinText}" Placeholder="0"
                               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark=#064E3B}"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="💾  Guardar Registro" Command="{Binding SaveCommand}"
                    FontSize="16" FontAttributes="Bold"
                    HeightRequest="54" CornerRadius="16"
                    Margin="0,4,0,20"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

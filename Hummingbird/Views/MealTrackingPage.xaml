<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Hummingbird.Views.MealTrackingPage"
             Title="Comidas">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <Label Text="📊 Seguimiento de Comidas" FontSize="24" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" Padding="0,8,0,0"/>

            <!-- Period Picker -->
            <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="12">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="📅 Período:" FontSize="14" VerticalOptions="Center"/>
                    <Picker ItemsSource="{Binding Periods}"
                            SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                            HorizontalOptions="FillAndExpand"/>
                </HorizontalStackLayout>
            </Border>

            <Label Text="{Binding PeriodSummary}" FontSize="13" TextColor="{StaticResource Gray500}"/>

            <!-- Meal Pair Cards -->
            <CollectionView ItemsSource="{Binding MealSummaries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Padding="16" Margin="0,4">
                            <VerticalStackLayout Spacing="12">

                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding MealEmoji}" FontSize="20"/>
                                    <Label Text="{Binding MealName}" FontSize="18" FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                                    <!-- Pre -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                        <Label Text="Pre" FontSize="13" TextColor="{StaticResource Gray500}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PreAverage, StringFormat='{0:F0}'}"
                                               FontSize="28" FontAttributes="Bold"
                                               TextColor="{Binding PreColor}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PreCount, StringFormat='{0} lecturas'}"
                                               FontSize="11" TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>

                                    <!-- Delta Arrow -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center"
                                                         HorizontalOptions="Center" Spacing="2">
                                        <Label Text="→" FontSize="20" TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding DeltaText}" FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray500}" HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>

                                    <!-- Post -->
                                    <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                        <Label Text="Post" FontSize="13" TextColor="{StaticResource Gray500}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PostAverage, StringFormat='{0:F0}'}"
                                               FontSize="28" FontAttributes="Bold"
                                               TextColor="{Binding PostColor}"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding PostCount, StringFormat='{0} lecturas'}"
                                               FontSize="11" TextColor="{StaticResource Gray400}"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="8" Padding="40">
                        <Label Text="🍽️" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="Sin datos de comidas" FontSize="18" FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Registra mediciones pre y post comida para ver el análisis"
                               FontSize="14" TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

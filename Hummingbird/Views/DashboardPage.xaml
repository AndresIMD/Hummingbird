<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Hummingbird.Views.DashboardPage"
             Title="Inicio">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <VerticalStackLayout Spacing="4" Padding="0,8,0,0">
                <Label Text="🩸 Hummingbird" FontSize="28" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"/>
                <Label Text="Control de Glicemia" FontSize="16"
                       TextColor="{StaticResource Gray500}"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Promedio" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Text="{Binding AverageGlucose}" FontSize="36" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"/>
                        <Label Text="mg/dL · 7 días" FontSize="11" TextColor="{StaticResource Gray400}"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="En rango" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Text="{Binding PercentInRange}" FontSize="36" FontAttributes="Bold"
                               TextColor="{StaticResource GlucoseInRange}"/>
                        <Label Text="objetivo · 7 días" FontSize="11" TextColor="{StaticResource Gray400}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Última medición" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="{Binding LastGlucose}" FontSize="36" FontAttributes="Bold"
                                   TextColor="{Binding LastGlucoseColor}"/>
                            <Label Text="{Binding GlucoseTrend}" FontSize="28"
                                   TextColor="{Binding GlucoseTrendColor}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="{Binding LastGlucoseTime}" FontSize="11" TextColor="{StaticResource Gray400}"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Insulina total" FontSize="13" TextColor="{StaticResource Gray500}"/>
                        <Label Text="{Binding TotalInsulin}" FontSize="36" FontAttributes="Bold"
                               TextColor="{StaticResource Gray600}"/>
                        <Label Text="aplicada · 7 días" FontSize="11" TextColor="{StaticResource Gray400}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Chart -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16" IsVisible="{Binding HasChartData}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📈 Últimos 7 días" FontSize="16" FontAttributes="Bold"/>
                    <GraphicsView x:Name="GlucoseChart"
                                  Drawable="{Binding ChartDrawable}"
                                  HeightRequest="200"/>
                </VerticalStackLayout>
            </Border>

            <!-- HbA1c Estimado -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16" Opacity="{Binding HasReliableHbA1c, Converter={StaticResource BoolToOpacityConverter}}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="🧬 HbA1c Estimado" FontSize="16" FontAttributes="Bold"/>
                        <Label Text="{Binding HbA1cPeriod}" FontSize="11" TextColor="{StaticResource Gray400}"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding EstimatedHbA1c}" FontSize="36" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- TIR Detallado -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16" Opacity="{Binding HasReliableTir, Converter={StaticResource BoolToOpacityConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🎯 Tiempo en Rango" FontSize="16" FontAttributes="Bold"/>
                    <Label Text="{Binding TirConfidenceNote}" FontSize="11" TextColor="{StaticResource Gray400}" Margin="0,-6,0,0"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                        <BoxView Grid.Row="0" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                                 Color="{StaticResource GlucoseLow}" VerticalOptions="Center"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding RangeLowText}" FontSize="13" VerticalOptions="Center"/>
                        <Label Grid.Row="0" Grid.Column="2" Text="{Binding TirLow}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource GlucoseLow}" HorizontalTextAlignment="End"/>

                        <BoxView Grid.Row="1" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                                 Color="{StaticResource GlucoseInRange}" VerticalOptions="Center"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding RangeInRangeText}" FontSize="13" VerticalOptions="Center"/>
                        <Label Grid.Row="1" Grid.Column="2" Text="{Binding TirInRange}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource GlucoseInRange}" HorizontalTextAlignment="End"/>

                        <BoxView Grid.Row="2" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                                 Color="{StaticResource GlucoseHigh}" VerticalOptions="Center"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding RangeHighText}" FontSize="13" VerticalOptions="Center"/>
                        <Label Grid.Row="2" Grid.Column="2" Text="{Binding TirHigh}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource GlucoseHigh}" HorizontalTextAlignment="End"/>

                        <BoxView Grid.Row="3" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                                 Color="{StaticResource GlucoseVeryHigh}" VerticalOptions="Center"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding RangeVeryHighText}" FontSize="13" VerticalOptions="Center"/>
                        <Label Grid.Row="3" Grid.Column="2" Text="{Binding TirVeryHigh}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource GlucoseVeryHigh}" HorizontalTextAlignment="End"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Calendar -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="◀" FontSize="20"
                               TextColor="{StaticResource Primary}" Padding="8,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousMonthCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Grid.Column="1" Text="{Binding CalendarMonthText}"
                               FontSize="16" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="▶" FontSize="20"
                               TextColor="{StaticResource Primary}" Padding="8,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextMonthCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <Label Grid.Column="0" Text="L" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="1" Text="M" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="2" Text="X" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="3" Text="J" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="4" Text="V" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="5" Text="S" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="6" Text="D" FontSize="11" TextColor="{StaticResource Gray400}" HorizontalTextAlignment="Center"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding CalendarDays}" SelectionMode="None"
                                    HeightRequest="{Binding CalendarHeight}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="7"
                                             HorizontalItemSpacing="3" VerticalItemSpacing="3"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{Binding BackgroundColor}"
                                        HeightRequest="44" Stroke="Transparent">
                                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                                        <Label Text="{Binding DayText}" FontSize="12"
                                               TextColor="{Binding TextColor}" HorizontalOptions="Center"/>
                                        <Label Text="{Binding AverageText}" FontSize="8"
                                               TextColor="{Binding TextColor}" HorizontalOptions="Center"
                                               IsVisible="{Binding HasData}"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Objetivo Diario -->
            <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Tertiary}}"
                    Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="📋 Objetivo del día" FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"/>
                            <Label Text="{Binding StatusMessage}" FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="0">
                            <Label Text="{Binding DailyGoalText}" FontSize="28" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="mediciones" FontSize="10"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Grid>

                    <ProgressBar Progress="{Binding DailyGoalProgress}"
                                 ProgressColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                                 HeightRequest="6"/>

                    <Label Text="{Binding StreakText}" FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

                    </VerticalStackLayout>
                </ScrollView>

            </ContentPage>
